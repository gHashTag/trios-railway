{
  "$schema": "https://railway.com/railway.schema.json",
  "name": "RT-1 - FP32 Final Baseline (seed=100)",
  "description": "Trinity-3k model with FP32 format, d_model=2048, lr=0.003, steps=60000, tiny_shakespeare data (real training baseline)",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "/Users/playra/trios-trainer-igla/target/release/trios-train",
    "healthcheckPath": "/healthz",
    "restartPolicyType": "ON_FAILURE",
    "numReplicas": 1
  },
  "variables": {
    "SEED": {
      "default": "100"
    },
    "STEPS": {
      "default": "60000"
    },
    "LR": {
      "default": "0.003"
    },
    "HIDDEN": {
      "default": "2048"
    },
    "CTX": {
      "default": "24"
    },
    "NEON_DATABASE_URL": {
      "isOptional": false
    },
    "RUST_LOG": {
      "default": "info"
    }
  }
}
